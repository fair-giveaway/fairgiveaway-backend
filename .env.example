# ── Managed Databases ─────────────────────────────────────

# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/fairgiveaway?retryWrites=true&w=majority

# Upstash Redis REST API
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── X (Twitter) Scraper Config ──────────────────────────

# Sacrificial X Account Cookies
X_AUTH_TOKEN=your-auth-token-cookie
X_CT0=your-ct0-cookie

# Puppeteer Chromium Path (used in Docker, uncomment for local macOS/Windows if needed)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ── SMTP (Contact Form — Zoho Mail) ──────────────────────

# SMTP server configuration (Zoho Mail)
# Port 465 = implicit TLS (secure=true); port 587 = STARTTLS (secure=false).
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true

# Inbox that receives contact-form submissions.
EMAIL_USER=support@fairgiveaway.online

# Use a Zoho app-specific password (Account → Security → App Passwords),
# never the raw account password.
EMAIL_PASS=your-zoho-app-specific-password
